generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Admin {
  id       String @id
  email    String @unique
  password String
  name     String
}

model Member {
  id          String    @id @default(cuid())
  name        String
  username    String    @unique
  password    String
  phone       String    @default("")
  whatsapp    String
  birthDate   String    @default("") @map("birth_date")
  entryDate   String    @default("") @map("entry_date")
  monthlyFee  Float
  dueDate     Int       @map("due_date")
  status      String    @default("Ativo")
  observations String   @default("")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  payments    Payment[]
  receipts    PaymentReceipt[]

  @@map("members")
}

model Payment {
  id          String   @id @default(cuid())
  memberId    String   @map("member_id")
  month       String
  paymentDate String?  @map("payment_date")
  amount      Float
  method      String?
  status      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  receipts    PaymentReceipt[]

  @@map("payments")
}

model PaymentReceipt {
  id          String   @id @default(cuid())
  paymentId   String   @map("payment_id")
  memberId    String   @map("member_id")
  description String
  amount      Float
  paidAt      String   @map("paid_at")
  status      String   @default("Pendente")
  reviewedBy  String?  @map("reviewed_by")
  reviewedAt  String?  @map("reviewed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("payment_receipts")
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  date        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("expenses")
}

model AppSettings {
  id                String   @id @default(cuid())
  pixKey            String   @default("") @map("pix_key")
  bankName          String   @default("") @map("bank_name")
  accountName       String   @default("") @map("account_name")
  defaultMonthlyFee Float    @default(50) @map("default_monthly_fee")
  defaultDueDate    Int      @default(10) @map("default_due_date")
  houseGuidelines   String   @default("") @map("house_guidelines")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
